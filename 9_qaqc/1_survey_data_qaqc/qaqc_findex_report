# Indicateurs cles de l inclusion financiere

```{r indicators, results='asis'}
for (ind in p$indicators) {
  cat(glue("\n\n## {ind$label}\n\n"))
  overall <- tryCatch(
    weighted_prop(df, ind$numerator_expr, ind$denominator_filter, p),
    error = function(e) data.frame(n_wtd=NA,pct=NA,ci_low=NA,ci_high=NA)
  )
  print(qaqc_table(
    data.frame(Niveau="Global",
               N_pondere=format(overall$n_wtd,big.mark=","),
               Taux=round(overall$pct,1),
               IC95=glue("[{round(overall$ci_low,1)}, {round(overall$ci_high,1)}]")),
    caption=glue("Estimation globale ponderee — {ind$label}"),
    col.names=c("Niveau","N pondere (denom.)","Taux (%)","IC 95%")))
  for (by_var in intersect(ind$breakdown_vars, names(df))) {
    breakdown <- tryCatch(
      weighted_prop_by(df, ind$numerator_expr, ind$denominator_filter, p, by_var),
      error = function(e) NULL
    )
    if (is.null(breakdown) || all(is.na(breakdown$pct))) next
    print(qaqc_table(
      breakdown |>
        mutate(IC95=glue("[{round(ci_low,1)}, {round(ci_high,1)}]")) |>
        select(-ci_low,-ci_high),
      caption=glue("{ind$label} — par {by_var}"),
      col.names=c(by_var,"N pondere","Taux (%)","IC 95%")))
    if (nrow(breakdown) <= 15) {
      p_plot <- ggplot(breakdown,
                       aes(x=fct_reorder(as.character(.data[[by_var]]),pct), y=pct)) +
        geom_col(fill="#1F618D", alpha=0.85, width=0.65) +
        geom_errorbar(aes(ymin=ci_low,ymax=ci_high),
                      width=0.25, color="#C0392B", linewidth=0.6) +
        geom_text(aes(label=paste0(round(pct,1),"%")), hjust=-0.15, size=2.8) +
        coord_flip() +
        scale_y_continuous(limits=c(0,min(108,max(breakdown$pct,na.rm=TRUE)*1.25)),
                           labels=label_percent(scale=1)) +
        labs(x=NULL, y="Taux (%)",
             title=glue("{ind$label}"),
             subtitle=glue("Par {by_var} — barres d erreur: IC 95%")) +
        theme_qaqc()
      print(p_plot)
      cat("\n\n")
    }
  }
}
```

