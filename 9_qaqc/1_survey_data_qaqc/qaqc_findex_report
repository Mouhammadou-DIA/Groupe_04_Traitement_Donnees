# ── Survey design ──────────────────────────────────────────────────────────────
build_svy_design <- function(df, p) {
  svydesign(
    ids     = if (!is.null(p$cluster_var) && p$cluster_var %in% names(df))
                as.formula(paste0("~", p$cluster_var)) else ~1,
    strata  = if (!is.null(p$strata_var) && p$strata_var %in% names(df))
                as.formula(paste0("~", p$strata_var)) else NULL,
    weights = as.formula(paste0("~", p$weight_var)),
    data    = df, nest = TRUE
  )
}

# ── Weighted stats ─────────────────────────────────────────────────────────────
wtd_stats <- function(svy, var, weight_var) {
  df_v <- svy$variables
  x <- df_v[[var]]; w <- df_v[[weight_var]]
  ok <- !is.na(x) & !is.na(w) & w > 0
  x_ok <- x[ok]; w_ok <- w[ok]
  n_eff <- round(sum(w_ok)^2 / sum(w_ok^2))
  svy_sub <- subset(svy, !is.na(svy$variables[[var]]))
  est_mean <- svymean(as.formula(paste0("~", var)), svy_sub, na.rm=TRUE)
  w_mean <- coef(est_mean)[1]; w_se <- SE(est_mean)[1]
  est_var  <- svyvar(as.formula(paste0("~", var)), svy_sub, na.rm=TRUE)
  w_sd     <- sqrt(as.numeric(est_var)[1])
  wtd_q <- tryCatch(
    Hmisc::wtd.quantile(x_ok, weights=w_ok, probs=c(0,.25,.5,.75,1)),
    error = function(e) {
      ord <- order(x_ok); cw <- cumsum(w_ok[ord])/sum(w_ok)
      sapply(c(0,.25,.5,.75,1), function(q) x_ok[ord][which(cw>=q)[1]])
    }
  )
  data.frame(
    Statistic = c("N (non-missing)","N (missing)","Effective N","Sum of weights",
                  "Weighted mean","Weighted SE","Weighted std dev",
                  "Min","P25","Median","P75","Max"),
    Value = c(format(sum(ok),big.mark=","), format(sum(!ok),big.mark=","),
              format(n_eff,big.mark=","), format(round(sum(w_ok)),big.mark=","),
              round(w_mean,2), round(w_se,4), round(w_sd,2),
              round(wtd_q[1],2), round(wtd_q[2],2), round(wtd_q[3],2),
              round(wtd_q[4],2), round(wtd_q[5],2))
  )
}

wtd_freq <- function(svy, var, weight_var) {
  df_v <- svy$variables |> filter(!is.na(.data[[var]]))
  df_v |> group_by(.data[[var]]) |>
    summarise(N_wtd = sum(.data[[weight_var]]), .groups="drop") |>
    arrange(desc(N_wtd)) |>
    mutate(Pct_wtd=round(N_wtd/sum(N_wtd)*100,1), Cum_pct=cumsum(Pct_wtd),
           N_wtd=round(N_wtd)) |>
    rename(Category=1)
}

weighted_prop <- function(df, numerator_expr, denom_filter, p) {
  df_d <- df |> filter(eval(parse(text=denom_filter)))
  if (nrow(df_d)==0) return(data.frame(n_wtd=0,pct=NA,ci_low=NA,ci_high=NA))
  svy_d <- build_svy_design(df_d, p)
  svy_d$variables$.ind <- as.numeric(eval(parse(text=numerator_expr), envir=svy_d$variables))
  est <- svymean(~.ind, svy_d, na.rm=TRUE); ci <- confint(est, level=0.95)
  data.frame(n_wtd=round(sum(df_d[[p$weight_var]],na.rm=TRUE)),
             pct=coef(est)[1]*100, ci_low=ci[1]*100, ci_high=ci[2]*100)
}

weighted_prop_by <- function(df, numerator_expr, denom_filter, p, by_var) {
  df |> filter(eval(parse(text=denom_filter)), !is.na(.data[[by_var]])) |>
    group_by(.data[[by_var]]) |>
    group_map(~ {
      res <- tryCatch(weighted_prop(.x, numerator_expr, "TRUE", p),
                      error = function(e) data.frame(n_wtd=nrow(.x),pct=NA,ci_low=NA,ci_high=NA))
      res[[by_var]] <- .y[[by_var]]; res
    }) |> bind_rows() |> relocate(all_of(by_var))
}
