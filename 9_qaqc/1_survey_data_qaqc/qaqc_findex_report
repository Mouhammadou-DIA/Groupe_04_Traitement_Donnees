## Valeurs manquantes

```{r missing}
na_df <- df |>
  summarise(across(everything(), ~sum(is.na(.)))) |>
  pivot_longer(everything(), names_to="Variable", values_to="N_missing") |>
  mutate(
    Pct_missing = round(N_missing/n_rows*100,1),
    Statut = case_when(
      Pct_missing == 0   ~ "Complet",
      Pct_missing < 10   ~ "< 10%",
      Pct_missing < 50   ~ "10 - 50%",
      TRUE               ~ "> 50%"
    )
  ) |>
  filter(N_missing > 0) |>
  arrange(desc(Pct_missing))

qaqc_table(na_df,
  caption="Valeurs manquantes par variable (variables avec au moins un NA)",
  col.names=c("Variable","N manquants","% manquant","Statut"))
