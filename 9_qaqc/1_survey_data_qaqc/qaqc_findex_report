# Analyse univariee

## Variables numeriques

```{r numeric-univariate, results='asis'}
for (v in intersect(p$vars_numeric, names(df))) {
  if (all(is.na(df[[v]]))) next
  cat(glue("\n\n### {v}\n\n"))
  stats <- wtd_stats(svy_design, v, p$weight_var)
  print(qaqc_table(stats, caption=glue("Statistiques descriptives ponderees — {v}")))
  df_v <- df |> filter(!is.na(.data[[v]]), !is.na(.data[[p$weight_var]]))
  p_hist <- ggplot(df_v, aes(x=.data[[v]], weight=.data[[p$weight_var]])) +
    geom_histogram(fill="#2E86C1", color="white", bins=30, alpha=0.85) +
    scale_x_continuous(labels=label_comma()) +
    labs(x=v, y="Effectif pondere", title=glue("Distribution ponderee — {v}")) +
    theme_qaqc()
  p_box <- ggplot(df_v |> filter(!is.na(code_pays)),
                  aes(x=fct_reorder(code_pays, .data[[v]], median),
                      y=.data[[v]], fill=code_pays)) +
    geom_boxplot(alpha=0.7, outlier.size=0.8, outlier.color="#C0392B",
                 show.legend=FALSE) +
    coord_flip() +
    labs(x=NULL, y=v, title="Par pays") +
    theme_qaqc()
  print(p_hist + p_box + plot_layout(widths=c(2,1)))
  cat("\n\n")
}
```

